{
  "name": "cf-container-service",
  "version": "1.0.0",
  "main": "container-service.js",
  "scripts": {
    "start": "node container-service.js",
    "start:v2": "node container-service-v2.js",
    "setup": "./setup-images.sh",
    "test": "node tests/run-tests.js",
    "test:unit": "jest tests/container-service.test.js",
    "test:watch": "jest --watch",
    "dev": "nodemon container-service-v2.js",
    "tunnel": "echo 'LocalTunnel replaced with Cloudflare Worker. Deploy cloudflare-worker.js to Workers.'"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "redis": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1",
    "wrangler": "^4.18.0",
    "ws": "^8.18.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}
